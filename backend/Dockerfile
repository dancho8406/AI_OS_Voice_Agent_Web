# 1. Използваме официален, олекотен образ на Python 3.11 за Облака
FROM python:3.11-slim

# 2. Настройваме работната директория вътре в контейнера
WORKDIR /app

# 3. Копираме списъка с нужните библиотеки
COPY requirements.txt .

# 4. Инсталираме библиотеките без кеширане, за да спестим място в Облака
RUN pip install --no-cache-dir -r requirements.txt

# 5. Копираме целия код на бекенда в контейнера
COPY . .

# 6. Указваме на контейнера да слуша на порт 8000, както е по проект
EXPOSE 8000

# 7. Командата, с която Google Cloud ще стартира FastAPI бекенда ни
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
